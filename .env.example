# Supabase (required)
SUPABASE_URL="https://zpvkbwovurryqqqvdxzb.supabase.co"
SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."
SUPABASE_SERVICE_ROLE_KEY="sb_secret_..."

VITE_SUPABASE_URL="https://zpvkbwovurryqqqvdxzb.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."
VITE_SUPABASE_PROJECT_ID="zpvkbwovurryqqqvdxzb"

# Database setup only (from Supabase Dashboard → Settings → Database)
SUPABASE_DB_PASSWORD="your_database_password"
# Optional full URI override:
# SUPABASE_DB_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres"

# Razorpay (optional — for online payments)
# RAZORPAY_KEY_ID=""
# RAZORPAY_KEY_SECRET=""

# CJ Dropshipping (product import + auto fulfillment)
# Get API Key: CJ Dashboard → Authorization → API → Add API → Type: API Key
CJ_API_KEY=""
# Optional: refresh token for long-lived auth (returned on first getAccessToken call)
# CJ_REFRESH_TOKEN=""
# USD to INR rate for pricing imported products
CJ_USD_INR=85
# Markup % added on top of CJ cost when importing (default 45)
CJ_MARKUP_PERCENT=45
# CJ order payment: 2=balance auto-pay, 3=create order only (pay on CJ dashboard)
CJ_PAY_TYPE=3
# Shipping method name from CJ (e.g. CJPacket Ordinary, CJPacket Sensitive)
# Shiprocket (optional — auto AWB + shipping labels)
# SHIPROCKET_API_EMAIL="api@yourdomain.com"
# SHIPROCKET_API_PASSWORD=""
# SHIPROCKET_PICKUP_LOCATION="Primary"
# SHIPROCKET_WEBHOOK_SECRET="your-random-secret-for-x-api-key-header"
