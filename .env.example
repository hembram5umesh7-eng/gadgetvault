# =============================================================================
# GadgetVault — Environment Variables (copy to .env for local dev)
# Full guide: docs/DEVELOPER_HANDOFF.md
# Never commit .env or real secrets to git.
# =============================================================================

# --- Supabase (required) ---
SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."
SUPABASE_SERVICE_ROLE_KEY="sb_secret_..."

VITE_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."
VITE_SUPABASE_PROJECT_ID="YOUR_PROJECT_ID"

# Database migrations only (Supabase Dashboard → Settings → Database)
SUPABASE_DB_PASSWORD="your_database_password"
# SUPABASE_DB_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres"

# --- Site URLs (required for OAuth + webhooks) ---
VITE_APP_URL=http://localhost:8080
VITE_APP_PUBLIC_URL=https://gadgetvault.in
# VITE_APP_FALLBACK_HTTPS=https://gadgetvault.in

# --- Shopify Headless Storefront (required — product pages) ---
VITE_SHOPIFY_STORE_DOMAIN=gharstoreessential.myshopify.com
VITE_SHOPIFY_STOREFRONT_TOKEN=""

# --- Shopify Dev Dashboard App (recommended — OAuth, auto token refresh) ---
SHOPIFY_CLIENT_ID=""
SHOPIFY_CLIENT_SECRET=""
# Legacy static token (optional fallback if OAuth not used)
SHOPIFY_ADMIN_ACCESS_TOKEN=""

# Headless publication ID (gadgetvault sales channel)
SHOPIFY_HEADLESS_PUBLICATION_ID=gid://shopify/Publication/290413740347

# Webhook HMAC secret (Shopify Dev Dashboard → Webhooks)
SHOPIFY_WEBHOOK_SECRET=""

# --- Shopify Customer Account API (optional — Shopify customer login) ---
SHOPIFY_CUSTOMER_ACCOUNT_SHOP_ID=""
SHOPIFY_CUSTOMER_ACCOUNT_AUTHORIZE_URL=""
SHOPIFY_CUSTOMER_ACCOUNT_TOKEN_URL=""
SHOPIFY_CUSTOMER_ACCOUNT_LOGOUT_URL=""
VITE_SHOPIFY_CUSTOMER_ACCOUNT_CLIENT_ID=""

# --- Razorpay (optional — online payments; can also set via Admin → Payments) ---
# RAZORPAY_KEY_ID=""
# RAZORPAY_KEY_SECRET=""
# RAZORPAY_WEBHOOK_SECRET=""

# --- Shiprocket (optional — shipping labels + tracking) ---
# SHIPROCKET_API_EMAIL=""
# SHIPROCKET_API_PASSWORD=""
# SHIPROCKET_PICKUP_LOCATION="Primary"
# SHIPROCKET_WEBHOOK_SECRET=""

# --- Dropship India (optional — sub-admin portal URL) ---
# DROPSHIP_INDIA_PORTAL_URL=https://dropshipindia.live

# --- Store contact & legal (optional) ---
# VITE_STORE_LEGAL_NAME=""
# VITE_STORE_EMAIL=""
# VITE_STORE_PHONE=""
# VITE_STORE_WHATSAPP=""
# VITE_STORE_GSTIN=""
# VITE_STORE_ADDRESS_LINE1=""
# VITE_STORE_ADDRESS_CITY=""
# VITE_STORE_ADDRESS_STATE=""
# VITE_STORE_ADDRESS_PINCODE=""
# VITE_STORE_FREE_SHIPPING_MIN=999
# VITE_STORE_SHIPPING_FEE=79
# VITE_STORE_DELIVERY_DAYS="3–7 business days"
